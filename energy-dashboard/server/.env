# ================= SERVER CONFIG =================
API_PORT=5000
API_HOST=0.0.0.0
DEBUG=False
CORS_ORIGINS=*

# ================= HARDWARE CONFIG =================
# Relay GPIO Pin (BCM numbering - GPIO17)
RELAY_PIN=17

# ADC Calibration Constants
# ACS712 Current Sensor (185mV/A for -5A to +5A version)
ACS_SENS=0.185

# Voltage Divider Gain (resistor ratio: 10k/(1k+10k) with amplification)
VOLT_GAIN=260

# ADC Sampling Parameters
ADC_SAMPLES=400
ADC_SAMPLE_DELAY=0.001

# ================= THRESHOLD CONFIG =================
# Over-voltage detection (India: 230V nominal, 250V tolerance)
OVERVOLTAGE_THRESHOLD=245

# Overload protection (stop at 1500W)
OVERLOAD_THRESHOLD=1500

# High consumption alert (warn at 1000W)
HIGH_CONSUMPTION_THRESHOLD=1000

# Offline detection timeout (seconds)
OFFLINE_TIMEOUT=10

# Overload duration before relay-off (seconds)
OVERLOAD_DURATION=10

# ================= BILLING CONFIG =================
# Cost per kWh (₹ per kWh - India electricity rate)
COST_PER_KWH=8.5

# Billing cycle start date (day of month: 1-28)
BILLING_CYCLE_START=1

# ================= FREQUENCY & POWER FACTOR =================
# Grid frequency (50Hz for India, 60Hz for US)
GRID_FREQUENCY=50.0

# Power factor estimate (typical AC load: 0.9-0.95)
POWER_FACTOR_ESTIMATE=0.95

# ================= DATA RETENTION =================
# Maximum historical samples per metric type
MAX_HISTORICAL_SAMPLES=100

# Daily summary retention (days)
DAILY_SUMMARY_RETENTION_DAYS=30
